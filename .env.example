PORT=4000
SOTRA_SERVER_URL=https://hsbtrans.mudrowak.de
SOTRA_SERVER_CTRANSLATE_URL=http://localhost:3005
SOTRA_SERVER_FAIRSEQ_URL=http://localhost:3000
LIBRETRANSLATE_URL=http://localhost:5004
VOSK_SERVER_URL=ws://localhost:2700
#VOSK_SERVER_URL=https://webcaptioner-spoz.mudrowak.de/
BAMBORAK_SERVER=http://127.0.0.1:8080

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/webcaptioner

# Legacy JWT (optional, für alte Tokens)
JWT_SECRET_KEY=your-jwt-secret

# Free-Login Passwort (ohne Account)
FREE_PASSWORD=your-free-password

# Lokaler Admin (wird beim ersten Start in MongoDB angelegt)
DB_ADMIN_FIRSTNAME=Admin
DB_ADMIN_LASTNAME=User
DB_ADMIN_EMAIL=admin@example.com
DB_ADMIN_PASSWORD=your-admin-password

# Keycloak – Basis-URL (ohne trailing slash), z.B. http://localhost:8080
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=webcaptioner

# Backend Client (confidential, Direct Access Grants Enabled)
# Für Login und Token-Refresh
KEYCLOAK_CLIENT_ID=webcaptioner-backend
KEYCLOAK_CLIENT_SECRET=your-backend-client-secret
f4uiN3Pwf1YC6nwRHJ6zzCMbG254JAcN

# Service Account Client (confidential, Service Accounts Enabled)
# Rollen zuweisen: realm-management → manage-users, view-users, create-user, etc.
KEYCLOAK_SERVICE_ACCOUNT_CLIENT_ID=webcaptioner-service
KEYCLOAK_SERVICE_ACCOUNT_CLIENT_SECRET=your-service-account-client-secret
MDIZGUkBAa2YpKa9qZ7ygZhzCaM1ulBf

# Realm-Rolle für Admins in der App
KEYCLOAK_ADMIN_ROLE=admin
